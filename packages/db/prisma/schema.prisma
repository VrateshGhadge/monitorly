generator client {
  provider = "prisma-client"
  output   = "./../generated/prisma-client"
  runtime  = "workerd"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(uuid())
  username      String     @unique
  email         String     @unique
  password_hash String
  name          String?
  createdAt     DateTime   @default(now())
}

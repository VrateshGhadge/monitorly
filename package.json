{
  "name": "dev-plus",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "npm run db:migrate --workspace=@repo/db",
    "db:studio": "npm run db:studio --workspace=@repo/db",
    "db:studio:stable": "PRISMA_QUERY_COMPILER=0 npx -y node@22.13.1 ./node_modules/prisma/build/index.js studio --config ./packages/db/prisma.studio.config.ts --browser default",
    "db:studio:legacy": "node ./scripts/run-legacy-studio.cjs"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prettier": "^3.7.4",
    "turbo": "^2.9.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.5.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "allowScripts": {
    "@prisma/engines@7.7.0": true,
    "esbuild@0.27.3": true,
    "fsevents@2.3.3": true,
    "prisma@7.7.0": true,
    "sharp@0.34.5": true,
    "workerd@1.20260410.1": true
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "zod": "^4.4.3"
  }
}
